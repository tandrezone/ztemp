{
    "name": "tandrezone/ztemp",
    "description": "A lightweight, secure PHP template engine supporting {{ $variable }}, @include(), and @foreach()/@endforeach directives.",
    "type": "library",
    "license": "MIT",
    "keywords": ["template", "engine", "templating"],
    "authors": [
        {
            "name": "tandrezone"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tandrezone\\Ztemp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tandrezone\\Ztemp\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
